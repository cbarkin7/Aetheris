# =============================================================================
# AETHERIS — Plantilla de Variables de Entorno
# Copia este fichero a .env y rellena tus valores
# =============================================================================

# -----------------------------------------------------------------------------
# Proveedor LLM principal: OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# AWS Bedrock (fallback automático cuando OpenAI no responde)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=                  # Opcional: credenciales temporales STS
AWS_REGION=eu-west-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0

# -----------------------------------------------------------------------------
# HuggingFace Hub (descarga de modelos — faster-whisper, etc.)
# Token de tipo READ (solo lectura sobre repos públicos) — sin permisos de escritura.
# Crear en: https://huggingface.co/settings/tokens → New token → Read
# Necesario para evitar rate-limiting al descargar modelos como faster-whisper.
# -----------------------------------------------------------------------------
HF_TOKEN=hf_...

# -----------------------------------------------------------------------------
# Speech-to-Text local (faster-whisper — sin coste de API)
# Tamaños: tiny | base | small | medium | large-v2 | large-v3
# -----------------------------------------------------------------------------
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu                  # cpu o cuda (si tienes GPU)
WHISPER_COMPUTE_TYPE=int8           # int8 (CPU rápido) | float16 (GPU) | float32

# -----------------------------------------------------------------------------
# Observabilidad LangSmith
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=aetheris

# -----------------------------------------------------------------------------
# Búsqueda web Tavily (MCP)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-...

# -----------------------------------------------------------------------------
# Google Workspace OAuth (MCP — Calendar y Gmail)
#
# Servidores MCP utilizados:
#   Calendar → @cocal/google-calendar-mcp
#   Gmail    → @gongrzhe/server-gmail-autoauth-mcp
#
# Configuración:
#   1. Descarga el fichero OAuth2 desde Google Cloud Console
#      (APIs & Services → Credentials → OAuth 2.0 Client ID → Desktop app → Download JSON)
#      y guárdalo en data/google/ (p. ej. client_secret_aetheris.json).
#      Activa las APIs: Google Calendar API y Gmail API.
#
#   2. Obtén el REFRESH_TOKEN ejecutando el flujo OAuth una sola vez:
#        npx @cocal/google-calendar-mcp auth
#      Abre el navegador, autoriza la app y pega aquí el refresh_token.
#
#   AETHERIS generará automáticamente los ficheros de token en data/google/
#   al arrancar (sin flujo interactivo) usando el REFRESH_TOKEN configurado.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_SECRET_FILE=data/google/client_secret_aetheris.json
GOOGLE_REFRESH_TOKEN=1//...
# Fallback si no existe el fichero client_secret_*.json (opcional cuando el fichero está presente)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Google Drive MCP (stdio)
# Usa @modelcontextprotocol/server-gdrive vía npx.
# Para autorizar Drive por primera vez (obtiene el token en data/google/.drive-token.json):
#   $env:GOOGLE_OAUTH_CREDENTIALS="data/google/client_secret_aetheris.json"  # Windows PowerShell
#   npx @modelcontextprotocol/server-gdrive auth
# Asegúrate de que la API de Google Drive está activada en Google Cloud Console.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# mem0.ai (memoria conversacional)
# Dejar vacío MEM0_API_KEY para modo local con Chroma
# -----------------------------------------------------------------------------
MEM0_API_KEY=
MEM0_ORG_ID=
MEM0_PROJECT_ID=

# -----------------------------------------------------------------------------
# Configuración de la aplicación
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=cambiar-en-produccion

# Rutas de datos (relativas a la raíz del proyecto)
CHROMA_PERSIST_DIR=data/chroma_db
SQLITE_CHECKPOINTS_PATH=data/sqlite/checkpoints.db
SQLITE_MEMORY_PATH=data/sqlite/memory.db
UPLOADS_DIR=data/uploads

# Selección de modelo LLM
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.0

# Ajustes RAG
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_RETRIEVAL_K=5
RAG_SCORE_THRESHOLD=0.3

# Guardrails de seguridad
GUARDRAILS_ENABLED=true
GUARDRAILS_MAX_INPUT_LENGTH=8000
GUARDRAILS_REDACT_PII=true
GUARDRAILS_BLOCK_INJECTIONS=true

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8501

# Streamlit
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Despliegue en Hugging Face Spaces (Docker)
#
# Para desplegar en HF Spaces, configura estos secretos en la UI de HF Spaces:
#   Settings → Repository secrets
#
# OPENAI_API_KEY       → tu clave OpenAI
# LANGSMITH_API_KEY    → tu clave LangSmith
# TAVILY_API_KEY       → tu clave Tavily
# GOOGLE_REFRESH_TOKEN → refresh token OAuth2 de Google
# GOOGLE_CLIENT_SECRET_JSON → contenido base64 de client_secret_aetheris.json
#   Obtener con: base64 -w 0 data/google/client_secret_aetheris.json
#   (Linux/Mac) o: [Convert]::ToBase64String([IO.File]::ReadAllBytes('data\google\client_secret_aetheris.json'))
#   (PowerShell)
#
# En produccion (HF Spaces Docker):
#   CORS_ORIGINS=http://localhost:7860
#   STREAMLIT_PORT=7860
#   API_BASE_URL=http://localhost:8000
# -----------------------------------------------------------------------------
